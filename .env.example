# Syncpedia — deploy at https://app.syncpedia.in only

VITE_SITE_URL=https://app.syncpedia.in

# Google Sign-In — https://console.cloud.google.com/apis/credentials
# Create OAuth client type: Web application (NOT Android for the website)
# Authorized JavaScript origins: https://app.syncpedia.in http://localhost:3000
# Use the SAME Client ID for both lines below. After editing .env on VPS: pm2 restart syncpedia-community
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

NODE_ENV=production
PORT=3000
HOST=127.0.0.1

DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

ADMIN_SECRET=change-me-min-16-characters

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notify@app.syncpedia.in

CRON_SECRET=
